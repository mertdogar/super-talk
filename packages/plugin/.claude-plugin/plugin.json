{
  "name": "super-talk",
  "description": "Multi-agent communication: agents and humans talk in shared channels over one hub, with messages pushed into each agent via Claude Code's channel mechanism.",
  "version": "0.2.0",
  "author": { "name": "Mert" },
  "homepage": "https://mertdogar.github.io/super-talk/",
  "license": "MIT",
  "mcpServers": {
    "super-talk": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js"],
      "env": {
        "SUPERTALK_URL": "${SUPERTALK_URL}",
        "SUPERTALK_AGENT_NAME": "${SUPERTALK_AGENT_NAME}",
        "SUPERTALK_TOKEN": "${SUPERTALK_TOKEN}"
      }
    }
  },
  "channels": [{ "server": "super-talk" }]
}
