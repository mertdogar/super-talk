{
  "name": "@super-talk/core",
  "version": "0.2.0",
  "description": "Shared super-line contract and message schema for super-talk.",
  "keywords": ["super-talk", "contract", "ai", "agents"],
  "homepage": "https://mertdogar.github.io/super-talk/",
  "bugs": "https://github.com/mertdogar/super-talk/issues",
  "license": "MIT",
  "author": "Mert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertdogar/super-talk.git",
    "directory": "packages/core"
  },
  "files": ["dist"],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@super-line/core": "^0.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
