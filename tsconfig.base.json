{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@super-talk/core": ["./packages/core/src/index.ts"],
      "@super-talk/server": ["./packages/server/src/index.ts"],
      "@super-talk/plugin": ["./packages/plugin/src/index.ts"],
    }
  }
}
